generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id    String @id @default(cuid())
  name  String @unique
  users User[]

  @@map("roles")
}

model User {
  id                 String              @id @default(cuid())
  name               String
  username           String              @unique
  password           String
  roleId             String
  role               Role                @relation(fields: [roleId], references: [id])
  borrowerId         String?             @unique
  borrower           Borrower?           @relation(fields: [borrowerId], references: [id])
  transactions       Transaction[]
  auditLogs          AuditLog[]
  consumableRequests ConsumableRequest[] @relation("RequestSubmitter")
  reviewedRequests   ConsumableRequest[] @relation("RequestReviewer")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([borrowerId])
  @@map("users")
}

/// Requester registry: staff and faculty (borrow / consumable release tracking)
model Borrower {
  id               String        @id @default(cuid())
  fullName         String
  /// Unique employee or faculty ID number
  idNumber         String        @unique @map("student_id")
  personType       PersonType    @default(STAFF)
  department       String
  officeUnit       String?       @map("program_section")
  contactPhone     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  transactions       Transaction[]
  user               User?
  consumableRequests ConsumableRequest[]

  @@map("borrowers")
}

enum PersonType {
  STAFF
  FACULTY
}

model Category {
  id    String @id @default(cuid())
  name  String @unique
  items Item[]

  @@map("categories")
}

enum InventoryType {
  BORROWABLE
  CONSUMABLE
}

/// Inventory item; equipmentProgram defaults to CRIMINOLOGY per study scope
model Item {
  id                 String          @id @default(cuid())
  name               String
  description        String?
  categoryId         String
  reorderLevel       Int             @default(10)
  equipmentProgram   String          @default("CRIMINOLOGY")
  inventoryType      InventoryType   @default(BORROWABLE)
  category           Category        @relation(fields: [categoryId], references: [id])
  transactions       Transaction[]
  consumableRequests ConsumableRequest[]
  qrCode             QRCode?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@map("items")
}

enum ConsumableRequestStatus {
  PENDING
  CANVASSING
  FOR_VOUCHER
  APPROVED
  REJECTED
  FULFILLED
}

/// Faculty/staff consumable request — catalog item or off-catalog (custom name)
model ConsumableRequest {
  id                String                  @id @default(cuid())
  requestNumber     String                  @unique
  userId            String
  borrowerId        String
  itemId            String?
  customItemName    String?
  customDescription String?
  quantity          Int
  notes             String?
  status            ConsumableRequestStatus @default(PENDING)
  reviewedById      String?
  reviewedAt        DateTime?
  reviewNotes       String?
  user              User                    @relation("RequestSubmitter", fields: [userId], references: [id])
  borrower          Borrower                @relation(fields: [borrowerId], references: [id])
  item              Item?                   @relation(fields: [itemId], references: [id], onDelete: SetNull)
  reviewedBy        User?                   @relation("RequestReviewer", fields: [reviewedById], references: [id])
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  @@index([userId])
  @@index([borrowerId])
  @@index([itemId])
  @@index([status])
  @@map("consumable_requests")
}

model Transaction {
  id         String          @id @default(cuid())
  itemId     String
  userId     String
  borrowerId String?
  type       TransactionType
  quantity   Int
  notes      String?
  item       Item            @relation(fields: [itemId], references: [id], onDelete: Restrict)
  user       User            @relation(fields: [userId], references: [id])
  borrower   Borrower?       @relation(fields: [borrowerId], references: [id])
  createdAt  DateTime        @default(now())

  @@map("transactions")
}

enum TransactionType {
  IN
  OUT
  RETURN
}

model QRCode {
  id     String @id @default(cuid())
  itemId String @unique
  value  String @unique
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("qr_codes")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String?
  entityId  String?
  details   String?
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@map("audit_logs")
}
